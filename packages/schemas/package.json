{
  "name": "@is-pinoy-dev/schemas",
  "version": "1.3.0",
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "generate:schema": "tsx scripts/generate-schema.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
