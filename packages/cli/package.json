{
  "name": "@is-pinoy-dev/cli",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "is-pinoy": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "dotenv": "^17.4.2",
    "figlet": "^1.8.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@is-pinoy-dev/registry": "workspace:*",
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.15.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.3"
  },
  "exports": {
    ".": "./dist/index.js"
  }
}
