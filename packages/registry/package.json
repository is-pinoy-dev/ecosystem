{
  "name": "@is-pinoy-dev/registry",
  "version": "0.0.5",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@is-pinoy-dev/schemas": "workspace:*",
    "@is-pinoy-dev/validate": "workspace:*",
    "dotenv": "^17.4.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vitest": "^3.1.3"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./core/*": "./dist/core/*",
    "./providers/*": "./dist/providers/*"
  }
}
