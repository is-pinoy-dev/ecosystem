{
  "name": "@is-pinoy-dev/registry",
  "version": "0.0.10",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@is-pinoy-dev/schemas": "workspace:*",
    "@is-pinoy-dev/validate": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./core/*": "./dist/core/*",
    "./providers/*": "./dist/providers/*"
  }
}
