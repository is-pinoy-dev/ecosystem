{
  "name": "@is-pinoy-dev/validate",
  "version": "1.0.2",
  "type": "module",
  "bin": {
    "validate": "./dist/bin.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@is-pinoy-dev/schemas": "workspace:*",
    "figlet": "catalog:",
    "picocolors": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/figlet": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js"
  }
}
