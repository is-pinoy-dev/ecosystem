# Auth.js (next-auth v5) — https://authjs.dev/getting-started/deployment
# Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=

# GitHub OAuth app credentials — https://github.com/settings/developers
# Callback URL: <origin>/api/auth/callback/github (e.g. http://localhost:3001/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Postgres connection string (Neon/Supabase/self-hosted). When set, the
# dashboard reads registry data from the database (kept current by the sync
# workflow POSTing to /api/registry/events). When unset, it falls back to
# reading the is-pinoy-dev/domains repo via the GitHub API.
# Apply the schema with: pnpm --filter dashboard db:migrate
DATABASE_URL=

# Shared secret for POST /api/registry/events. Generate with:
# openssl rand -hex 32 — set the same value in the domains repo's Actions
# secrets so the sync workflow can authenticate.
REGISTRY_SYNC_SECRET=

# Optional: raises the unauthenticated GitHub API rate limit when listing
# registry subdomains in the no-database fallback. Works without it.
GITHUB_TOKEN=
