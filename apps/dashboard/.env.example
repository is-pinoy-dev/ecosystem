# Auth.js (next-auth v5) — https://authjs.dev/getting-started/deployment
# Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=

# GitHub OAuth app credentials — https://github.com/settings/developers
# Callback URL: <origin>/api/auth/callback/github (e.g. http://localhost:3001/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Only needed on Vercel *preview* deployments, whose URLs change per commit.
# Point this at a stable deployment's auth route so the fixed GitHub OAuth
# callback still works: https://dashboard.is-pinoy.dev/api/auth
# The proxy deployment must share the same AUTH_SECRET. Leave unset in
# production and locally, where the origin is already stable.
AUTH_REDIRECT_PROXY_URL=

# Cloudflare D1 (SQLite) accessed over the D1 HTTP API. When all three are set
# the dashboard reads registry data from D1 (kept current by the sync workflow
# POSTing to /api/registry/events). When any is unset, it falls back to reading
# the is-pinoy-dev/domains repo via the GitHub API.
# Create the DB with: pnpm dlx wrangler d1 create dashboard-db
# Apply the schema with: pnpm --filter dashboard db:migrate
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
# API token scoped to D1:Edit — https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_D1_API_TOKEN=

# Shared secret for POST /api/registry/events. Generate with:
# openssl rand -hex 32 — set the same value in the domains repo's Actions
# secrets so the sync workflow can authenticate.
REGISTRY_SYNC_SECRET=

# Optional: raises the unauthenticated GitHub API rate limit when listing
# registry subdomains in the no-database fallback. Works without it.
GITHUB_TOKEN=
